rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function billingDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/private/billing);
    }

    function isPremium() {
      return signedIn()
        && billingDoc().data.isPremium == true
        && (
          !('expiresAt' in billingDoc().data)
          || billingDoc().data.expiresAt > request.time
        );
    }

    function isMember(spaceId) {
      return signedIn()
        && request.auth.uid in get(
          /databases/$(database)/documents/syncSpaces/$(spaceId)/meta/info
        ).data.memberUids;
    }

    match /users/{uid} {
      match /profile/{doc} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
      match /private/{doc} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow write: if signedIn()
          && request.auth.uid == uid
          && doc != 'billing';
      }
    }

    match /syncSpaces/{spaceId} {
      match /meta/info {
        allow read: if isPremium() && isMember(spaceId);
        allow create: if isPremium()
          && signedIn()
          && request.resource.data.createdBy == request.auth.uid
          && request.auth.uid in request.resource.data.memberUids;
        allow update: if isPremium() && isMember(spaceId);
      }

      match /entities/{entityId} {
        allow read: if isPremium() && isMember(spaceId);
        allow create, update: if isPremium()
          && isMember(spaceId)
          && request.resource.data.modifiedBy == request.auth.uid
          && request.resource.data.type is string
          && request.resource.data.modifiedAt is timestamp;
        allow delete: if false;
      }
    }

    match /invites/{code} {
      allow read: if signedIn();
      allow create: if isPremium()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
